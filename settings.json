{
  "packages": [
    "npm:pi-mermaid",
    "npm:pi-agent-browser-native",
    "npm:pi-extension-manager",
    "npm:pi-mcp-adapter",
    "npm:pi-smart-fetch",
    "npm:pi-glance",
    "npm:@victor-software-house/pi-curated-themes",
    "npm:pi-subagents",
    "npm:pi-prompt-template-model",
    "npm:@eko24ive/pi-ask",
    "npm:@leonardorick/pi-web-search",
    "npm:pi-ollama-cloud",
    "npm:pi-alert",
    "npm:pi-working-vibe"
  ],
  "theme": "smyck",
  "powerline": "default",
  "transport": "sse",
  "defaultProvider": "ollama-cloud",
  "defaultModel": "kimi-k2.7-code",
  "defaultThinkingLevel": "xhigh",
  "quietStartup": true,
  "enabledModels": [
    "deepseek-v4-flash",
    "minimax-m3",
    "kimi-k2.7-code",
    "deepseek-v4-pro",
    "glm-5.2"
  ],
  "workingVibe": true,
  "workingVibeName": "startrek",
  "subagents": {
    "agentOverrides": {
      "scout": {
        "model": "deepseek-v4-flash",
        "thinking": "xhigh"
      },
      "planner": {
        "model": "glm-5.2",
        "thinking": "xhigh"
      },
      "worker": {
        "model": "glm-5.2",
        "thinking": "xhigh"
      },
      "reviewer": {
        "model": "kimi-k2.7-code",
        "thinking": "high"
      },
      "oracle": {
        "model": "glm-5.2",
        "thinking": "xhigh"
      },
      "context-builder": {
        "model": "deepseek-v4-pro",
        "thinking": "xhigh"
      },
      "researcher": {
        "model": "kimi-k2.7-code",
        "thinking": "high"
      },
      "delegate": {
        "model": "kimi-k2.7-code",
        "thinking": "high"
      }
    }
  }
}

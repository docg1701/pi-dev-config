{
  "packages": [
    "npm:pi-mermaid",
    "npm:pi-agent-browser-native",
    "npm:pi-extension-manager",
    "npm:pi-mcp-adapter",
    "npm:pi-smart-fetch",
    "npm:pi-powerline-footer",
    "npm:@victor-software-house/pi-curated-themes",
    "npm:pi-interview",
    "npm:pi-subagents",
    "npm:pi-prompt-template-model",
    "npm:pi-annotate",
    "npm:@eko24ive/pi-ask",
    "npm:@leonardorick/pi-web-search",
    "npm:pi-ollama-cloud",
    "npm:pi-alert"
  ],
  "theme": "brogrammer",
  "powerline": "default",
  "transport": "sse",
  "defaultProvider": "ollama-cloud",
  "defaultModel": "deepseek-v4-pro",
  "defaultThinkingLevel": "high",
  "quietStartup": true,
  "enabledModels": [
    "ollama-cloud/deepseek-v4-pro",
    "ollama-cloud/deepseek-v4-flash",
    "ollama-cloud/kimi-k2.6"
  ],
  "workingVibe": "startrek",
  "workingVibeMode": "file",
  "workingVibeModel": "ollama-cloud/deepseek-v4-flash",
  "subagents": {
    "agentOverrides": {
      "scout": { "model": "ollama-cloud/deepseek-v4-flash" },
      "planner": { "model": "ollama-cloud/deepseek-v4-pro" },
      "worker": { "model": "ollama-cloud/deepseek-v4-pro" },
      "reviewer": { "model": "ollama-cloud/kimi-k2.6" },
      "oracle": { "model": "ollama-cloud/deepseek-v4-pro" },
      "context-builder": { "model": "ollama-cloud/deepseek-v4-pro" },
      "researcher": { "model": "ollama-cloud/deepseek-v4-pro" },
      "delegate": { "model": "ollama-cloud/deepseek-v4-pro" }
    }
  }
}

+/**
+ * Map Ollama Cloud model families to pi thinking levels.
+ * Keys are pi levels (off/minimal/low/medium/high/xhigh).
+ * String value = send this to the provider; null = level unsupported/hidden.
+ */
+function getThinkingLevelMap(data: OllamaShowResponse): Record<string, string | null> | undefined {
+  const family = data.details?.family;
+  if (!family) return undefined;
+
+  // DeepSeek V4: only supports off, high ("high"), xhigh ("max")
+  if (family === "deepseek4") {
+    return { minimal: null, low: null, medium: null, high: "high", xhigh: "max" };
+  }
+
+  return undefined;
+}
